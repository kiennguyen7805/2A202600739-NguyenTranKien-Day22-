# Lab 22 (Modal) — template biến môi trường. Copy thành `.env` rồi paste key thật.
#   cp modal_app/.env.example modal_app/.env
#
# .env bị gitignore; .env.example commit được (không chứa secret).
# Modal đọc .env và nạp vào container qua Secret.from_dotenv().

# ── Tier + scope ─────────────────────────────────────────────
COMPUTE_TIER=BIGGPU          # BIGGPU (Qwen2.5-7B) | T4 (Qwen2.5-3B)

DO_DEPLOY=1                  # NB5 GGUF merge + smoke   (+6)
DO_BENCH=1                   # NB6 IFEval/GSM8K/MMLU    (+8)  ← phần LÂU nhất
DO_BETA_SWEEP=1             # β ∈ {0.05,0.1,0.5}       (+6)  ← +3 lần train DPO
DO_HF_PUSH=1                # push adapter + gguf HF   (+5/+3)

# ── DPO hyperparameters (default khớp deck §5.2) ─────────────
DPO_BETA=0.1
DPO_LR=5e-7
DPO_EPOCHS=1

# ── Judge cho NB4 + NB6 AlpacaEval-lite (bạn chọn OpenAI) ─────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JUDGE_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=          # để trống — chỉ cần nếu muốn cross-judge (+4)

# ── HuggingFace push (Option B = +5; GGUF release = +3) ──────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_USERNAME=                 # để trống = tự lấy từ token
# HF_REPO=                    # để trống = <username>/lab22-dpo-vn

# ── Weights & Biases (rigor add-on +2) — tuỳ chọn ────────────
# WANDB_API_KEY=
# WANDB_PROJECT=lab22-dpo

# ── Chi phí (để report tính đúng) ────────────────────────────
GPU_COST_USD_PER_HOUR=2.50   # A100 80GB ~ Modal
